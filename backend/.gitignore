# ─────────────────────────────────────────────────────────────────
# backend/.gitignore
# Files and directories that should NOT be committed to git.
# ─────────────────────────────────────────────────────────────────

# Python virtual environment
venv/
.venv/
env/

# Python bytecode cache
__pycache__/
*.py[cod]
*.pyo

# Environment variables (contains secrets — never commit!)
.env

# IDE / editor files
.vscode/
.idea/
*.swp

# OS files
.DS_Store
Thumbs.db

# Test & coverage outputs
.pytest_cache/
htmlcov/
.coverage
